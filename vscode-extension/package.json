{
  "name": "vericode-ai",
  "displayName": "VeriCode AI",
  "description": "Ground-Truth AI Coding Engine: Eliminate LLM hallucinations with verifiable, versioned, and searchable developer knowledge.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Formatters"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vericode-ai.query",
        "title": "VeriCode AI: Query with Context"
      },
      {
        "command": "vericode-ai.validate",
        "title": "VeriCode AI: Validate Current API Usage"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3"
  }
}
